#!/usr/bin/env bash
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
SIGN_ID="Developer ID Application: Brian Le (MWNX6V232Y)"
BUILD_KC_DEFAULT="$HOME/Library/Keychains/build.keychain-db"
APP_NAME="cmux.app"
INSTALL_PATH="/Applications/$APP_NAME"
DERIVED_DATA_PATH="$REPO/build"
BUILD_APP="$DERIVED_DATA_PATH/Build/Products/Release/$APP_NAME"
PINNED_ZIG_BIN="$HOME/.local/share/mise/installs/zig/0.15.2/bin"

cd "$REPO"

if [[ -x "$PINNED_ZIG_BIN/zig" ]]; then
  export PATH="$PINNED_ZIG_BIN:$PATH"
fi

if [[ -f "$HOME/.config/secrets/local.env" ]]; then
  source "$HOME/.config/secrets/local.env"
fi
if [[ -f "$HOME/.config/secrets/shell.env" ]]; then
  source "$HOME/.config/secrets/shell.env"
fi

BUILD_KC="${SIGNING_BUILD_KEYCHAIN_PATH:-$BUILD_KC_DEFAULT}"
BUILD_KC_PASSWORD="${SIGNING_BUILD_KEYCHAIN_PASSWORD:-}"

if [[ -z "$BUILD_KC_PASSWORD" ]]; then
  echo "ERROR: SIGNING_BUILD_KEYCHAIN_PASSWORD is not set" >&2
  exit 1
fi

echo "==> Unlocking build keychain"
security unlock-keychain -p "$BUILD_KC_PASSWORD" "$BUILD_KC"

echo "==> Preparing GhosttyKit"
"$REPO/scripts/ensure-ghosttykit.sh"

echo "==> Building Release with Developer ID signing"
trash "$DERIVED_DATA_PATH" 2>/dev/null || true
xcodebuild \
  -project GhosttyTabs.xcodeproj \
  -scheme cmux \
  -configuration Release \
  -derivedDataPath "$DERIVED_DATA_PATH" \
  -destination 'platform=macOS' \
  CODE_SIGN_IDENTITY="$SIGN_ID" \
  CODE_SIGN_STYLE=Manual \
  "OTHER_CODE_SIGN_FLAGS=--options=runtime --keychain=$BUILD_KC" \
  build

if [[ ! -d "$BUILD_APP" ]]; then
  echo "ERROR: $APP_NAME not found at $BUILD_APP" >&2
  exit 1
fi

echo "==> Verifying signature"
codesign --verify --deep --strict "$BUILD_APP"
codesign -dv "$BUILD_APP" 2>&1 | grep 'TeamIdentifier='

echo "==> Installing to $INSTALL_PATH"
pkill -x cmux || true
sleep 1
trash "$INSTALL_PATH" 2>/dev/null || true
cp -R "$BUILD_APP" "$INSTALL_PATH"
codesign --verify --deep --strict "$INSTALL_PATH"

echo "==> Launching"
env -u GIT_PAGER -u GH_PAGER open -g "$INSTALL_PATH"
sleep 2
"$INSTALL_PATH/Contents/Resources/bin/cmux" --version

echo "==> Deploying to MacBook (unchanged, via tar)"
ssh macbook 'osascript -e "tell application \"cmux\" to quit" 2>/dev/null; sleep 2; pkill -x cmux 2>/dev/null; sleep 1; trash /Applications/cmux.app 2>/dev/null || true'
(cd /Applications && tar cf - "$APP_NAME") | ssh macbook 'cd /Applications && tar xf -'
ssh macbook 'codesign --verify --deep --strict /Applications/cmux.app && open -g /Applications/cmux.app && sleep 2 && /Applications/cmux.app/Contents/Resources/bin/cmux --version'

echo "==> Done"
